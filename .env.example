# Gemini API - לניתוח וידאו (API שרת)
# השתמש באחד מהשמות - GEMINI_API_KEY או VITE_GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-api-key
# VITE_GEMINI_API_KEY=your-gemini-api-key

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# העתק לקובץ .env.local ועדכן את הערכים
# cp .env.example .env.local
#
# להרצה מקומית עם API (שימוש ב-.env.local):
# npm run dev:full
# (vercel dev - טוען .env.local ומריץ גם את ה-API)

# Gemini API - לניתוח וידאו (API שרת)
# השתמש באחד מהשמות - GEMINI_API_KEY או VITE_GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-api-key
# VITE_GEMINI_API_KEY=your-gemini-api-key

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# נדרש ל-API מקומי (ביטול מנוי, תשלומים) – מ-Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Takbull (ביטול מנוי / תשלומים)
TAKBULL_API_KEY=your-takbull-api-key
TAKBULL_API_SECRET=your-takbull-api-secret

# העתק לקובץ .env.local ועדכן את הערכים
# cp .env.example .env.local
#
# npm run dev - מריץ את האפליקציה + API מקומית (טוען .env.local)
